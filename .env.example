# Browser-safe Supabase configuration. Never put service-role keys or personal
# access tokens in this file or expose them through a VITE_ variable.
VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-or-publishable-key"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

# Browser-safe Google Maps key. Restrict it by your deployed origins and enable
# only Maps JavaScript API. Never use a Supabase access token or secret here.
VITE_GOOGLE_MAPS_API_KEY="your-browser-restricted-google-maps-key"

# Local-only test seed. Never expose or deploy this key to Vercel.
TEST_SUPABASE_SERVICE_ROLE_KEY=""
TEST_USER_PASSWORD=""
TEST_USER_SEED_CONFIRM=""
